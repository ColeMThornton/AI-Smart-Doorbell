import cv2                                          # computer vision library
from ultralytics import YOLO                        # object detection model library
import time                                         # used to keep track of time
def main():
    print("Loading YOLO11 Nano (NCNN format)...")
    model = YOLO("yolo11n.pt")                      # Load the YOLO11N model
    # model.export(format="ncnn")                     # Exports model to NCNN format
    vid = cv2.VideoCapture(0)                       # Open video stream
    vid.set(cv2.CAP_PROP_FRAME_WIDTH, 320)          # Lower resolution to speed up processing
    vid.set(cv2.CAP_PROP_FRAME_HEIGHT, 320)
    FPS = 5                                         # frame rate limit to improve performance
    last_time = 0
    print("Starting doorbell stream... Press 'q' to quit.")
    while True:
        ret, frame = vid.read()                     # Capture single frame from camera
        if not ret:                                 # If frame capture fails
            print("Camera error, retrying...")
            time.sleep(0.5)
            continue
        current_time = time.time()                  # get current time stamp
        if current_time - last_time >= 1/FPS:       # check if enough time has passed
            last_time = current_time
            results = model.predict(frame, imgsz=320, conf=0.5, verbose=False)  # conf sets 50% confidence threshold to filter false positives
            if len(results[0].boxes) > 0:           # check if any objects were detected
                annotated_frame = results[0].plot() # draw the bounding box and labels on frame
            else:
                annotated_frame = frame
        cv2.imshow("Smart Doorbell - YOLO11n", annotated_frame) # display camera feed with annotations
        if cv2.waitKey(1) & 0xFF == ord('q'):                   q# force quit program if 'q" is pressed
            break # exit loop
    
    # Clean up resources
    vid.release()
    cv2.destroyAllWindows()


    # test comment
if __name__ == "__main__":
    main()